# ==========================
# PendulumEdu Sub-project .gitignore
# ==========================

# Virtual Environment - NEVER commit this
venv/
env/
ENV/
.venv/

# Output files - generated by scraper, do NOT commit
output/*
!output/.gitkeep
*.pdf
*.json

# Log files
*.log
scraper.log

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
page_source.html

# Environment variables - NEVER commit
.env
.env.local
